# OpenStrmBridge Docker 环境变量配置
# 复制此文件为 .env 并根据需要修改

# 时区
TZ=Asia/Shanghai

# Docker 镜像版本标签（拉取预构建镜像时使用）
OPENSTRMBRIDGE_TAG=v0.1.7

# 后端服务端口
OPENSTRMBRIDGE_PORT=5174

# 302 代理端口（Go 代理引擎）
OPENSTRMBRIDGE_PROXY_PORT=8097

# 后端对外访问地址（Emby 回调等场景使用）
OPENSTRMBRIDGE_BACKEND_PUBLIC_URL=http://127.0.0.1:5174

# Emby 内 STRM 挂载路径
OPENSTRMBRIDGE_EMBY_MOUNT_PATH=/media/strm

# === 大规模部署优化参数 ===
# 媒体文件扫描上限（默认 500000 = 50万）
OPENSTRMBRIDGE_SCAN_MEDIA_FILE_LIMIT=500000

# 目录扫描上限（默认 50000 = 5万）
OPENSTRMBRIDGE_SCAN_DIRECTORY_LIMIT=50000

# STRM 索引写入防抖间隔（毫秒，默认 5000ms）
# 增大此值可减少磁盘写入频率，但容器异常退出可能丢失最近几秒的索引变更
OPENSTRMBRIDGE_STRM_INDEX_DEBOUNCE_MS=5000

# 任务列表内存缓存 TTL（毫秒，默认 60000ms = 1分钟）
# 10万+任务时避免每次翻页都读磁盘；任务增删改后自动失效
OPENSTRMBRIDGE_TASKS_CACHE_TTL_MS=60000
