{
  "name": "openstrmbridge",
  "private": true,
  "version": "0.1.8",
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "backend:dev": "node server/storage-check-server.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "lint:fast": "oxlint",
    "package:all": "node scripts/package-release.mjs --all",
    "package:current": "node scripts/package-release.mjs --current",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "antd": "^5.29.3",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "prettier": "^3.9.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
